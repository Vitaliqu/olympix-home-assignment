{
  "name": "roundtripguard",
  "version": "1.0.0",
  "scripts": {
    "audit": "ts-node cli/scaling-audit.ts",
    "test": "jest --runInBand",
    "test:ts": "jest --runInBand",
    "test:forge": "forge test -vvv",
    "test:fuzz": "forge test --match-contract RoundTripInvariantTest -vvv",
    "test:poc": "forge test --match-contract BalancerAttackReplay -vvv",
    "test:all": "jest --runInBand && forge test -vvv"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.ts"],
    "globals": {
      "ts-jest": {
        "tsconfig": {
          "module": "commonjs",
          "esModuleInterop": true
        }
      }
    }
  },
  "dependencies": {
    "@solidity-parser/parser": "^0.18.0",
    "axios": "^1.6.0",
    "commander": "^12.0.0",
    "ethers": "^6.11.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
